# Copy this file to .env and fill in your Supabase project's values.
# Find these in Supabase: Project Settings -> API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# REQUIRED for food search and barcode scanning: USDA FoodData Central API key.
# This app uses USDA FoodData Central as its ONLY food database — the
# authoritative US source, with ~600k branded and generic foods (real
# manufacturer-submitted nutrition labels and UPC/barcode data). There is
# no other database as a fallback, so without this key the Food Log's
# search and barcode scanner won't return results.
# Get a free key in ~30 seconds at https://fdc.nal.usda.gov/api-guide.html
# Add this as a Vercel environment variable the same way you added the Supabase ones.
VITE_USDA_API_KEY=YOUR_USDA_KEY_HERE

# REQUIRED for push notifications (water/weight/food reminders): the
# PUBLIC half of the VAPID keypair. Safe to expose client-side — it's
# the private half that must stay server-only (set as VAPID_PRIVATE_KEY
# on whatever runs api/send-notifications.js, never in this file or
# anywhere with a VITE_ prefix). See NOTIFICATIONS_SETUP.md for the full
# deployment walkthrough, including where this exact key pair came from.
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE
